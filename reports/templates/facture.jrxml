	<parameter name="id" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT a.id AS id_article,
    a.libelle,
    a.description,
    a.prix_vente,
    a.quantite_disponible,
    m.id AS id_m,
    m.prix,
    m.quantite AS quantite_m,
    m.operation,
    m.facture_id,
    f.client,
    f.when_done AS when_done_f,
    f.montantlettre,
    f.montantchiffre,
    f.when_imprime,
    m.montant_mouvement,
    m.is_rejet,
    f.is_transfert ,
    f.montant_client,
    f.montant_client - f.montantchiffre AS montant_remis
   FROM stock.v_article a,
    stock.mouvement m,
    stock.facture f
  WHERE a.id = m.article_id 
  AND f.id = m.facture_id
  AND f.id::character varying =  $P{id} ;]]>
	</queryString>
