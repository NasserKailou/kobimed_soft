	<queryString>
		<![CDATA[SELECT id, libelle, consultation, nom_patient, numero_consul, age, 
tel_patient, date_consultation, is_deleted, when_done, 
consultations, who_done, is_soin, montant, nom_partenaire,
taux_couverture, montant_pris_en_charge, montant_net_a_payer
	FROM public.v_soins
where CAST(when_done AS DATE) between CAST($P{date1} AS DATE)   and  CAST($P{date2} AS DATE)]]>
	</queryString>
