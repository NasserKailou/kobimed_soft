	<parameter name="id" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT DISTINCT 
   p.id_article, 
   p.libelle, 
   p.description, 
   p.prix_vente,
   p.quantite_disponible, 
   p.id_m, 
   p.prix,
   p.quantite_m,
   p.operation, 
   p.when_done_m, 
   p.facture_id, 
   p.montant_mouvement, 
   p.is_ok, 
   p.libelle_range,
   p.id_range, 
   p.is_rejet
  FROM stock.v_mouvement p
  WHERE p.id_article::character varying  =    $P{id} 
  ORDER BY  p.when_done_m asc;]]>
	</queryString>
