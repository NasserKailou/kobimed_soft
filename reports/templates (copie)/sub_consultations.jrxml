	<parameter name="id" class="java.sql.Timestamp"/>
	<queryString>
		<![CDATA[SELECT id, numero_consul, type_consultation, libelle_type, patient, nom_patient, age, partenaire_id,
 nom_partenaire, taux_couverture, tel_patient,prix_consultation, montant_consultation,montant_en_lettre, somme_recu, 
 somme_remise, montant_pris_en_charge, montant_a_payer, is_closed, is_deleted, when_done,who_done
	FROM public.v_consultations 
	where CAST(when_done AS DATE)  =  CAST($P{id} AS DATE) and montant_a_payer <>0
	order by id]]>
	</queryString>
